---
const posts = [
  {
    id: "behind-the-scenes-echo",
    title: "Behind the Scenes: How 'Echo' Was Made with AI Voice Synthesis",
    author: "Maya Chen",
    date: "2026-03-28",
  },
  {
    id: "meetup-recap-march",
    title: "March Meetup Recap — Exploring Real-Time AI Video Generation",
    author: "Jordan Liu",
    date: "2026-03-15",
  },
  {
    id: "festival-submissions-open",
    title: "Festival 2026 Submissions Are Now Open",
    author: "GenTO Team",
    date: "2026-03-01",
  },
];
---

<section class="relative">
  <!-- Section header — padded from rails -->
  <div class="max-w-[var(--container-max)] mx-auto px-[var(--container-padding)] pt-14 pb-6 md:pt-20 md:pb-8">
    <h2 class="text-2xl md:text-4xl font-bold text-white tracking-tight pl-4 md:pl-6" style="font-family: 'Playfair Display', Georgia, serif;">
      Latest from our Community
    </h2>
  </div>

  <!-- Top border of the post list -->
  <div class="border-h"></div>

  <!-- Posts region with bright vertical borders -->
  <div class="relative max-w-[var(--container-max)] mx-auto px-[var(--container-padding)]">
    <!-- Left vertical border -->
    <div class="hidden md:block absolute inset-y-0 left-[var(--container-padding)]">
      <div class="border-v h-full"></div>
    </div>
    <!-- Right vertical border -->
    <div class="hidden md:block absolute inset-y-0 right-[var(--container-padding)]">
      <div class="border-v h-full"></div>
    </div>

    <div class="card-group-glow">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class:list={[
            "post-card group block",
            i > 0 ? "" : "",
          ]}
        >
          <div class="py-5 md:py-6 px-4 md:px-6 flex items-center gap-5 md:gap-8">
            {/* Thumbnail placeholder */}
            <div class="hidden md:flex shrink-0 w-16 h-16 border border-white/[0.08] items-center justify-center bg-white/[0.02]">
              <svg class="w-7 h-7 text-white/15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
              </svg>
            </div>

            {/* Text */}
            <div class="flex-1 min-w-0">
              <h3 class="text-sm md:text-base font-medium text-white/80 group-hover:text-white transition-colors truncate">
                {post.title}
              </h3>
              <p class="text-xs text-white/25 font-mono mt-1">
                {post.author} · {post.date}
              </p>
            </div>

            {/* Arrow */}
            <div class="shrink-0 arrow-link text-white/20 group-hover:text-white/60 transition-colors text-lg">
              →
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Bottom border of the post list -->
  <div class="border-h"></div>
</section>
