---
import FilmStill from "../merged/FilmStill.astro";
---
<section class="section" style="border-bottom:1px solid var(--line);">
  <div class="container">
    <div class="venue-grid">
      <div>
        <FilmStill seed={2} aspect="1454/720" image="/innis-empty.png" />
      </div>
      <div>
        <span class="eyebrow">Venue</span>
        <h2 style="margin-top:20px;font-family:var(--font-display);font-size:clamp(40px, 4.6vw, 64px);letter-spacing:-0.025em;font-weight:500;line-height:0.98;">
          Innis Town Hall,<br />
          <span style="font-family:var(--font-serif);font-style:italic;font-weight:400;color:var(--cyan);">a proper cinema.</span>
        </h2>
        <p style="margin-top:24px;font-size:18px;line-height:1.6;color:var(--ink-dim);max-width:480px;">
          A 200-seat theatre at the University of Toronto with proper projection and room to argue after the credits roll.
        </p>
        <div style="display:flex;gap:12px;margin-top:28px;flex-wrap:wrap;">
          <a class="btn btn-primary glitch-hover" href="mailto:festival@gento.ca?subject=I%20want%20to%20buy%20passes%20for%20GenTO%20Toronto%20AI%20Film%20Festival!">Get Passes →</a>
          <a class="btn btn-ghost" href="https://maps.app.goo.gl/o6HWon9K1d7Cmof76" target="_blank" rel="noopener noreferrer">Directions ↗</a>
        </div>
      </div>
    </div>
  </div>
</section>
