---
const NEWSLETTER_HREF = "mailto:meetups@gento.ca?subject=Subscribe%20me%20to%20the%20GenTO%20meetup%20newsletter!";
---
<section class="community-cta">
  <div class="halo" style="width:520px;height:520px;background:var(--cyan);top:-30%;right:-10%;opacity:0.18;"></div>
  <div class="halo" style="width:360px;height:360px;background:var(--yellow);bottom:-20%;left:-5%;opacity:0.14;"></div>
  <div class="community-cta-inner">
    <div>
      <span class="eyebrow" style="color:rgba(255,255,255,0.5);">Don't miss the next one</span>
      <h2>
        Get notified about<br />
        <em>upcoming events.</em>
      </h2>
    </div>
    <div class="community-cta-actions">
      <a class="btn btn-primary glitch-hover community-join-btn" href="https://discord.gg/P6YUV3qrpw">Join Discord →</a>
      <a class="btn btn-ghost glitch-hover" href={NEWSLETTER_HREF}>Newsletter</a>
    </div>
  </div>
</section>
