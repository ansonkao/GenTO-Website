---
import GenToMark from './GenToMark.astro';
---
<footer class="footer">
  <div class="footer-grid">
    <div>
      <div style="display:flex;align-items:center;gap:10px;color:var(--ink);">
        <GenToMark size={32} />
        <span style="font-family:var(--font-display);font-weight:600;font-size:22px;letter-spacing:-0.01em;">GenTO</span>
      </div>
      <p style="margin-top:20px;max-width:360px;color:var(--ink-dim);font-size:14px;line-height:1.6;">
        Toronto's premiere stage for AI-enhanced storytelling. A community of audacious makers and curious audiences, built for the next chapter of cinema.
      </p>
      <div style="margin-top:28px;display:flex;gap:14px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-dim);">
        <a href="https://discord.gg/P6YUV3qrpw">Discord ↗</a>
        <a href="#">Instagram ↗</a>
        <a href="#">YouTube ↗</a>
      </div>
    </div>

    <div>
      <h4>Community</h4>
      <div class="footer-links">
        <a href="/meetups">Monthly Meetups</a>
        <a href="https://discord.gg/P6YUV3qrpw">Join Discord</a>
      </div>
    </div>

    <div>
      <h4>Festival</h4>
      <div class="footer-links">
        <a href="/festival">About the Festival</a>
        <a href="https://filmfreeway.com/gentoaifilmfestival" target="_blank" rel="noopener noreferrer">Submit a Film ↗</a>
        <a href="mailto:festival@gento.ca?subject=I%20want%20to%20buy%20passes%20for%20GenTO%20Toronto%20AI%20Film%20Festival!">Tickets</a>
        <a href="mailto:festival@gento.ca?subject=Sponsorship%20Inquiry%20-%20GenTO%20Toronto%20AI%20Film%20Festival">Sponsors</a>
      </div>
    </div>

    <div>
      <h4>Resources</h4>
      <div class="footer-links">
        <a href="/blog">Journal</a>
        <a href="mailto:festival@gento.ca?subject=Press%20Kit%20Request%20-%20GenTO">Press</a>
        <a href="mailto:festival@gento.ca?subject=General%20Inquiry%20-%20GenTO">Contact</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© 2026 GenTO Generative Arts Collective</span>
    <span>Cinema Evolved · Toronto, Canada</span>
  </div>
</footer>
