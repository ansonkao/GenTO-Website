---
const year = new Date().getFullYear();
---

<!-- Spacer between blog section and footer -->
<div class="spacer py-7 md:py-12"></div>

<footer class="relative pb-[60px]">
  <div class="max-w-[var(--container-max)] mx-auto px-[var(--container-padding)] py-6 md:py-8 flex flex-col md:flex-row items-center md:items-start justify-between gap-6 text-sm text-white/50">
    <div class="pl-4 md:pl-6 flex flex-col items-center md:items-start gap-2">
      <img src="/logo.svg" alt="GenTO" class="h-10 w-auto opacity-60" />
      <p>&copy; {year} GenTO Generative Arts Collective.</p>
      <p>Toronto, Ontario</p>
    </div>
    <div class="pr-4 md:pr-6 flex flex-col items-center md:items-end gap-4">
      <nav class="flex gap-6 text-base">
        <a href="/festival" class="hover:text-neon-pink transition-colors">Festival</a>
        <a href="/meetups" class="hover:text-neon-yellow transition-colors">Meetups</a>
