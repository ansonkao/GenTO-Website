---
const year = new Date().getFullYear();
---

<header class="relative z-20">
  <div class="max-w-[var(--container-max)] mx-auto px-[var(--container-padding)] py-4 flex items-center justify-between">
    <a href="/" class="pl-4 md:pl-6 opacity-80 hover:opacity-100 transition-opacity">
      <img src="/logo.svg" alt="GenTO" class="h-10 w-auto" />
    </a>
    <nav class="flex gap-6 text-base text-white/50 pr-4 md:pr-6">
      <a href="/festival" class="hover:text-neon-pink transition-colors">Festival</a>
      <a href="/meetups" class="hover:text-neon-yellow transition-colors">Meetups</a>
      <a href="https://discord.gg/gento" target="_blank" rel="noopener noreferrer" class="hover:text-neon-blue transition-colors inline-flex items-center gap-1">Discord<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg></a>
    </nav>
  </div>
  <div class="border-h"></div>
</header>
