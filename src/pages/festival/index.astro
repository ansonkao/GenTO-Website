---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";
---

<BaseLayout title="GenTO Film Festival — Dec 5, 2026">
  <Header />
  <section class="min-h-[60vh] flex items-center justify-center">
    <div class="max-w-[var(--container-max)] mx-auto px-[var(--container-padding)] text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Film Festival</h1>
      <p class="text-lg text-white/50">December 5, 2026 — Toronto, Ontario</p>
      <p class="text-base text-white/30 mt-6">More details coming soon.</p>
    </div>
  </section>
  <Footer />
</BaseLayout>
