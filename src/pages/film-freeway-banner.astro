---
// Standalone export-ready banner sized for FilmFreeway (2460 × 936).
// Visit /film-freeway-banner and screenshot at exact viewport for the asset.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GenTO — FilmFreeway Banner 2460×936</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --magenta: #ff2d92;
        --cyan: #00e5ff;
        --yellow: #ffe23a;
        --ink: #f4ecff;
        --ink-dim: #a29bb5;
        --ink-mute: #5a5469;
        --bg: #070509;
        --bg-2: #0d0a14;
        --line: rgba(244, 236, 255, 0.08);
        --line-bright: rgba(244, 236, 255, 0.18);
        --font-display: "Geist", system-ui, sans-serif;
        --font-mono: "Geist Mono", ui-monospace, monospace;
        --font-serif: "Instrument Serif", Georgia, serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: #000; }
      body {
        font-family: var(--font-display);
        color: var(--ink);
        display: flex; align-items: center; justify-content: center;
        min-height: 100vh;
      }

      .banner-wrap {
        width: 1230px; height: 468px;
        position: relative;
      }
      .banner {
        width: 2460px; height: 936px;
        position: absolute; top: 0; left: 0;
        transform: scale(0.5); transform-origin: top left;
        overflow: hidden;
        background:
          radial-gradient(ellipse at 18% 28%, rgba(255,45,146,0.20) 0%, transparent 55%),
          radial-gradient(ellipse at 82% 78%, rgba(0,229,255,0.16) 0%, transparent 55%),
          linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 100%);
      }

      .grid-bg {
        position: absolute; inset: 0; pointer-events: none; opacity: 0.55;
        background-image:
          linear-gradient(to right, rgba(244,236,255,0.04) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(244,236,255,0.04) 1px, transparent 1px);
        background-size: 80px 80px;
      }

      .scanlines {
        position: absolute; inset: 0; pointer-events: none; opacity: 0.18;
        background-image: repeating-linear-gradient(
          0deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 3px
        );
      }

      .crop {
        position: absolute; width: 56px; height: 56px;
        stroke: var(--yellow); stroke-width: 2.5; fill: none;
      }
      .crop-tl { top: 165px; left: 260px; }
      .crop-tr { top: 165px; right: 260px; }
      .crop-bl { bottom: 165px; left: 260px; }
      .crop-br { bottom: 165px; right: 260px; }

      .divider {
        position: absolute; left: 310px; right: 310px; height: 1px;
        background: var(--line-bright);
      }
      .divider.top { top: 285px; }
      .divider.bottom { bottom: 285px; }

      .stage {
        position: absolute; left: 0; right: 0; top: 50%;
        transform: translateY(-50%);
        text-align: center;
      }

      .tagline {
        font-family: var(--font-serif);
        font-style: italic; font-weight: 400;
        font-size: 180px; line-height: 1;
        letter-spacing: -0.025em;
        color: rgba(255, 255, 255, 0.25);
      }

      .status {
        position: absolute; top: 195px; left: 330px;
        display: inline-flex; align-items: center; gap: 16px;
        font-family: var(--font-mono);
        font-size: 26px; letter-spacing: 0.32em;
        text-transform: uppercase;
      }
      .status-dot {
        width: 16px; height: 16px; border-radius: 50%;
        background: var(--magenta);
        box-shadow: 0 0 24px var(--magenta);
      }
      .status-text { color: var(--yellow); }

      .edition {
        position: absolute; bottom: 195px; left: 330px;
        font-family: var(--font-mono);
        font-size: 26px; letter-spacing: 0.32em;
        text-transform: uppercase; color: rgba(255, 255, 255, 0.35);
      }

      .date {
        position: absolute; top: 195px; right: 330px;
        font-family: var(--font-mono);
        font-size: 26px; letter-spacing: 0.32em;
        text-transform: uppercase; color: var(--cyan);
      }

      .location {
        position: absolute; bottom: 195px; right: 330px;
        font-family: var(--font-mono);
        font-size: 26px; letter-spacing: 0.32em;
        text-transform: uppercase; color: var(--magenta);
      }
    </style>
  </head>
  <body>
    <div class="banner-wrap">
    <div class="banner">
      <div class="grid-bg"></div>
      <div class="scanlines"></div>

      <svg class="crop crop-tl" viewBox="0 0 56 56"><path d="M0 0 L28 0 M0 0 L0 28" /></svg>
      <svg class="crop crop-tr" viewBox="0 0 56 56"><path d="M56 0 L28 0 M56 0 L56 28" /></svg>
      <svg class="crop crop-bl" viewBox="0 0 56 56"><path d="M0 56 L28 56 M0 56 L0 28" /></svg>
      <svg class="crop crop-br" viewBox="0 0 56 56"><path d="M56 56 L28 56 M56 56 L56 28" /></svg>

      <div class="divider top"></div>
      <div class="divider bottom"></div>

      <div class="status">
        <span class="status-dot"></span>
        <span class="status-text">Submissions Open</span>
      </div>

      <div class="edition">001 — Inaugural Edition</div>

      <div class="stage">
        <div class="tagline">Cinema, Evolved</div>
      </div>

      <div class="date">Dec 05–06, 2026</div>

      <div class="location">Innis Town Hall · Toronto</div>
    </div>
    </div>
  </body>
</html>
