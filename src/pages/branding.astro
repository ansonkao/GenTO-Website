      </div>
      <div class="brand-controls">
        <label class="toggle">
          <input type="checkbox" id="logosvg-toggle" />
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
          <span class="toggle-label">On white</span>
        </label>
        <button class="copy-btn" id="logosvg-copy-btn">Copy</button>
        <button class="copy-btn" id="logosvg-save-btn">Save</button>
        <span class="copy-status" id="logosvg-copy-status"></span>
      </div>
    </section>

    <section class="brand-section">
      <div class="brand-heading">/ GenTO Logo PNG</div>
      <div class="fflogo-wrap">
        <img class="fflogo-img" id="gento-logo-img" src="/gento-logo.png" alt="GenTO Logo" />
      </div>
      <div class="brand-controls">
        <button class="copy-btn" id="gento-logo-copy-btn">Copy</button>
        <button class="copy-btn" id="gento-logo-save-btn">Save</button>
        <span class="copy-status" id="gento-logo-copy-status"></span>
      </div>
    </section>

    <section class="brand-section">
      <div class="brand-heading">/ FilmFreeway Logo PNG</div>
      <div class="fflogo-wrap">
        <img class="fflogo-img" id="fflogo-img" src="/film-freeway-logo.png" alt="GenTO FilmFreeway Logo" />
      </div>
      <div class="brand-controls">
        <button class="copy-btn" id="fflogo-copy-btn">Copy</button>
        <button class="copy-btn" id="fflogo-save-btn">Save</button>
        <span class="copy-status" id="fflogo-copy-status"></span>
      </div>
    </section>

    <section class="brand-section">
      <div class="brand-heading">/ FilmFreeway Banner — 2808 × 936</div>
      <div class="ffb-wrap">
        <div class="ffb-banner" id="ffb-banner">
          <div class="ffb-grid"></div>
          <div class="ffb-scanlines"></div>

          <svg class="ffb-crop ffb-crop-tl" viewBox="0 0 56 56"><path d="M0 0 L28 0 M0 0 L0 28" stroke="#ffe23a" stroke-width="2.5" fill="none" /></svg>
          <svg class="ffb-crop ffb-crop-tr" viewBox="0 0 56 56"><path d="M56 0 L28 0 M56 0 L56 28" stroke="#ffe23a" stroke-width="2.5" fill="none" /></svg>
          <svg class="ffb-crop ffb-crop-bl" viewBox="0 0 56 56"><path d="M0 56 L28 56 M0 56 L0 28" stroke="#ffe23a" stroke-width="2.5" fill="none" /></svg>
          <svg class="ffb-crop ffb-crop-br" viewBox="0 0 56 56"><path d="M56 56 L28 56 M56 56 L56 28" stroke="#ffe23a" stroke-width="2.5" fill="none" /></svg>

          <div class="ffb-divider top"></div>
          <div class="ffb-divider bottom"></div>

          <div class="ffb-status">
            <span class="ffb-status-dot"></span>
            <span class="ffb-status-text">Submissions Open</span>
          </div>

          <div class="ffb-edition">001 — Inaugural Edition</div>

          <div class="ffb-stage">
            <div class="ffb-tagline">Cinema, Evolved</div>
          </div>

          <div class="ffb-date">Dec 05–06, 2026</div>
          <div class="ffb-location">Innis Town Hall · Toronto</div>
        </div>
      </div>
      <div class="brand-controls">
        <label class="toggle">
          <input type="checkbox" id="ffb-toggle" checked />
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
          <span class="toggle-label">Gradient</span>
        </label>
        <button class="copy-btn" id="ffb-copy-btn">Copy</button>
        <button class="copy-btn" id="ffb-save-btn">Save</button>
        <span class="copy-status" id="ffb-copy-status"></span>
      </div>
    </section>

    <section class="brand-section">
      <div class="brand-heading">/ FilmFreeway Logo — 512 × 512</div>
      <div class="ffl-banner" id="ffl-banner">
        <div class="ffl-grid"></div>
        <div class="ffl-scanlines"></div>

        <svg class="ffl-crop ffl-crop-tl" viewBox="0 0 28 28"><path d="M0 0 L14 0 M0 0 L0 14" stroke="#ffe23a" stroke-width="2" fill="none" /></svg>
        <svg class="ffl-crop ffl-crop-tr" viewBox="0 0 28 28"><path d="M28 0 L14 0 M28 0 L28 14" stroke="#ffe23a" stroke-width="2" fill="none" /></svg>
        <svg class="ffl-crop ffl-crop-bl" viewBox="0 0 28 28"><path d="M0 28 L14 28 M0 28 L0 14" stroke="#ffe23a" stroke-width="2" fill="none" /></svg>
        <svg class="ffl-crop ffl-crop-br" viewBox="0 0 28 28"><path d="M28 28 L14 28 M28 28 L28 14" stroke="#ffe23a" stroke-width="2" fill="none" /></svg>

        <div class="ffl-stage">
          <img class="ffl-logo" src="/logo.svg" alt="GenTO" />
          <div class="ffl-presents">Presents</div>
          <div class="ffl-stack">
            <div>Toronto</div>
            <div class="ffl-italic">AI Film</div>
            <div>Festival</div>
          </div>
        </div>
      </div>
      <div class="brand-controls">
        <label class="toggle">
          <input type="checkbox" id="ffl-toggle" checked />
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
          <span class="toggle-label">Hide content</span>
        </label>
        <button class="copy-btn" id="ffl-copy-btn">Copy</button>
        <button class="copy-btn" id="ffl-save-btn">Save</button>
        <span class="copy-status" id="ffl-copy-status"></span>
      </div>
    </section>

    <script is:inline>
      (function () {
        function setupToggle(toggleId, targetId, className) {
          var toggle = document.getElementById(toggleId);
          var target = document.getElementById(targetId);
          if (!toggle || !target) return;
          var apply = function () {
            if (toggle.checked) target.classList.add(className);
            else target.classList.remove(className);
          };
          toggle.addEventListener('change', apply);
          toggle.addEventListener('input', apply);
          apply();
        }

        function setupCopy(btnId, statusId, targetId, width, height, captureStyle) {
          var btn = document.getElementById(btnId);
          var status = document.getElementById(statusId);
          var target = document.getElementById(targetId);
          if (!btn || !status || !target) return;
          btn.addEventListener('click', async function () {
            if (!window.htmlToImage) {
              status.textContent = 'lib missing';
              return;
            }
            status.textContent = 'Capturing…';
            try {
              var blob = await window.htmlToImage.toBlob(target, {
                width: width, height: height,
                pixelRatio: 1,
                cacheBust: true,
                style: captureStyle || {},
              });
              if (!blob) { status.textContent = 'Capture failed'; return; }
              try {
                await navigator.clipboard.write([
                  new ClipboardItem({ 'image/png': blob }),
                ]);
                status.textContent = 'Copied!';
                setTimeout(function () { status.textContent = ''; }, 2000);
              } catch (err) {
                console.error(err);
                status.textContent = 'Clipboard denied';
              }
            } catch (err) {
              console.error(err);
              status.textContent = 'Capture failed';
            }
          });
        }

        function setupSave(btnId, statusId, targetId, filename, width, height, captureStyle) {
          var btn = document.getElementById(btnId);
          var status = document.getElementById(statusId);
          var target = document.getElementById(targetId);
          if (!btn || !status || !target) return;
          btn.addEventListener('click', async function () {
            if (!window.htmlToImage) {
              status.textContent = 'lib missing';
              return;
            }
            status.textContent = 'Saving…';
            try {
              var blob = await window.htmlToImage.toBlob(target, {
                width: width, height: height,
                pixelRatio: 1,
                cacheBust: true,
                style: captureStyle || {},
              });
              if (!blob) { status.textContent = 'Capture failed'; return; }
              var url = URL.createObjectURL(blob);
              var link = document.createElement('a');
              link.href = url;
              link.download = filename;
              document.body.appendChild(link);
              link.click();
              link.remove();
              setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
              status.textContent = 'Saved!';
              setTimeout(function () { status.textContent = ''; }, 2000);
            } catch (err) {
              console.error(err);
              status.textContent = 'Capture failed';
            }
          });
        }

        // Banner: gradient toggle + copy/save at native 2808×936 (drop the preview scale)
        setupToggle('ffb-toggle', 'ffb-banner', 'gradient-on');
        setupCopy('ffb-copy-btn', 'ffb-copy-status', 'ffb-banner', 2808, 936, { transform: 'none' });
        setupSave('ffb-save-btn', 'ffb-copy-status', 'ffb-banner', 'gento-banner-2808x936.png', 2808, 936, { transform: 'none' });

        // FilmFreeway Logo: hide-content toggle + copy/save at native 512×512
        setupToggle('ffl-toggle', 'ffl-banner', 'content-hidden');
        setupCopy('ffl-copy-btn', 'ffl-copy-status', 'ffl-banner', 512, 512);
        setupSave('ffl-save-btn', 'ffl-copy-status', 'ffl-banner', 'gento-logo-512x512.png', 512, 512);

        // Logo SVG: white/black toggle + copy/save at native 1401×513
        setupToggle('logosvg-toggle', 'logosvg-stage', 'on-white');
        setupCopy('logosvg-copy-btn', 'logosvg-copy-status', 'logosvg-stage', 1401, 513, { transform: 'none' });
        setupSave('logosvg-save-btn', 'logosvg-copy-status', 'logosvg-stage', 'gento-logo-1401x513.png', 1401, 513, { transform: 'none' });

        // GenTO Logo PNG: copy and save the original file
        (function () {
          var copyBtn = document.getElementById('gento-logo-copy-btn');
          var saveBtn = document.getElementById('gento-logo-save-btn');
          var status = document.getElementById('gento-logo-copy-status');
          if (copyBtn && status) {
            copyBtn.addEventListener('click', async function () {
              status.textContent = 'Copying…';
              try {
                var resp = await fetch('/gento-logo.png');
                var blob = await resp.blob();
                await navigator.clipboard.write([new ClipboardItem({ [blob.type]: blob })]);
                status.textContent = 'Copied!';
                setTimeout(function () { status.textContent = ''; }, 2000);
              } catch (e) { console.error(e); status.textContent = 'Failed'; }
            });
          }
          if (saveBtn && status) {
            saveBtn.addEventListener('click', function () {
              var a = document.createElement('a');
              a.href = '/gento-logo.png';
              a.download = 'gento-logo.png';
              document.body.appendChild(a);
              a.click();
              a.remove();
              status.textContent = 'Saved!';
              setTimeout(function () { status.textContent = ''; }, 2000);
            });
          }
        })();

        // FilmFreeway Logo PNG: copy and save the original file
        var fflogoCopyBtn = document.getElementById('fflogo-copy-btn');
        var fflogoSaveBtn = document.getElementById('fflogo-save-btn');
        var fflogoStatus = document.getElementById('fflogo-copy-status');

        if (fflogoCopyBtn && fflogoStatus) {
          fflogoCopyBtn.addEventListener('click', async function () {
            fflogoStatus.textContent = 'Copying…';
            try {
              var resp = await fetch('/film-freeway-logo.png');
              var blob = await resp.blob();
              await navigator.clipboard.write([new ClipboardItem({ [blob.type]: blob })]);
              fflogoStatus.textContent = 'Copied!';
              setTimeout(function () { fflogoStatus.textContent = ''; }, 2000);
            } catch (e) {
              console.error(e);
              fflogoStatus.textContent = 'Failed';
            }
          });
        }

        if (fflogoSaveBtn && fflogoStatus) {
          fflogoSaveBtn.addEventListener('click', function () {
            var a = document.createElement('a');
            a.href = '/film-freeway-logo.png';
            a.download = 'film-freeway-logo.png';
            document.body.appendChild(a);
            a.click();
            a.remove();
            fflogoStatus.textContent = 'Saved!';
            setTimeout(function () { fflogoStatus.textContent = ''; }, 2000);
          });
        }
      })();
    </script>
  </body>
</html>
